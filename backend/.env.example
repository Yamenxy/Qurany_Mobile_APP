# Application
APP_NAME=qurany-backend
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS (JSON list). Use ["*"] for local dev; lock down for production.
CORS_ORIGINS=["*"]

# ASR (faster-whisper)
# WHISPER_MODEL: tiny | base | small | medium | large-v3
WHISPER_MODEL=small
# WHISPER_COMPUTE_TYPE: int8 (CPU) | int8_float16 | float16 (GPU) | float32
WHISPER_COMPUTE_TYPE=int8
# WHISPER_DEVICE: auto | cpu | cuda
WHISPER_DEVICE=auto
WHISPER_BEAM_SIZE=5
ASR_LANGUAGE=ar

# Reference text (Surah Al-Naba is seeded locally under data/surah_naba/)
ALQURAN_API_BASE=https://api.alquran.cloud/v1
REFERENCE_FETCH_FALLBACK=true

# Comparison
SIMILARITY_THRESHOLD=0.6
